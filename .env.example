# =============================================================================
# クイックリファレンス（2026-07-02の結合テストで判明した必須/任意の整理。
# 詳細はREADME.md「トラブルシューティング：結合テストでよくある症状」参照）
#
# 【必須】YOUTUBE_API_KEY … 無いとyoutube収集全体が502になる
# 【任意】X_COOKIES_PATH + X_WEB_BEARER + X_GRAPHQL_USERBYSCREENNAME_ID
#         … 無くてもXは動くが実フォロワー数等が取れず0固定のまま
# 【任意】X_GRAPHQL_USERTWEETS_ID … 上記3つを設定した上でこれも無いと
#         engagementRateが常に0.0のまま（プロフィール本体の取得とは独立した
#         フェイルソフト項目。上の3つだけでは足りない点に注意）
# 【任意】INSTAGRAM_COOKIES_PATH … Instagramはこれが無くても実データがフル
#         取得できる。ブロック耐性向上・非公開フォロー中アカウント閲覧のみが目的
# 【対応不要】THREADS_*/TIKTOK_*のcookie系 … 未実装のため設定項目なし
#
# instagram/threads/tiktokの検索（keyword/hashtag/category）が0件になる場合、
# トークン不足ではなくDuckDuckGo（唯一の候補発見手段）への接続がネットワーク
# レベルでブロックされている可能性がある（README参照）。queryType=usernameの
# 完全一致検索はDiscoveryを経由しないため、この影響を受けない。
# =============================================================================

# YouTube Data API v3 キー（取得先: https://console.cloud.google.com/apis/credentials、"YouTube Data API v3" を有効化）
YOUTUBE_API_KEY=

# バックエンド独自のAPIキー（任意・空欄ならBearer認証チェックをスキップ）
BACKEND_API_KEY=

# X(Twitter) スクレイピングの節度設定（旧設定・後方互換のため残す）
X_SEARCH_MAX_CANDIDATES=3
X_REQUEST_JITTER_MIN=4
X_REQUEST_JITTER_MAX=8

# --- X(Twitter) 件数・ページネーション設定 ---
# 検索で最終的に返したい件数（フィルタ後の目標値、20〜50件を想定）
X_SEARCH_TARGET_COUNT=30
# 取得失敗・フィルタ除外を見込んで発見しておく候補数の上限
X_DISCOVERY_MAX_CANDIDATES=45
# Togetter探索: 検索結果ページの最大ページ数／記事ページの最大読み込み数
X_TOGETTER_MAX_PAGES=5
X_TOGETTER_MAX_ARTICLES=8
# DuckDuckGo html-lite探索の最大ページ数
X_DDG_MAX_PAGES=3
# プロフィール取得（ハイドレーション）の同時実行数
X_HYDRATE_CONCURRENCY=5
# 認証済みX GraphQL APIへのリクエスト間隔（秒）。通常のブラウザ利用に近い短い間隔でよい
X_API_JITTER_MIN=0.5
X_API_JITTER_MAX=1.5
# プロフィール取得結果のキャッシュ有効期限（秒）
X_PROFILE_CACHE_TTL=3600

# --- X(Twitter) 認証スクレイピング設定（任意・未設定なら非認証モードで動作） ---
# 【重要】以下はXアカウントの認証情報そのものです。絶対にリポジトリにコミットしない
# でください（.gitignoreでcookie系ファイルは除外済みですが、値を直接ここに書かない
# こと）。また、認証済みセッションを自動化してXの内部APIを呼ぶ行為はX利用規約に
# 抵触し得ます。ご自身のアカウントで自己責任にて利用し、可能であればサブアカウントの
# 利用や控えめな同時実行数/間隔設定を推奨します。
#
# 取得手順:
#   1. ご自身のXアカウントでブラウザにログインする
#   2. Cookie-Editor等の拡張機能で x.com のCookieをJSON配列としてエクスポートし、
#      リポジトリ外の場所（例: ~/.secrets/x_cookies.json）に保存する
#      （auth_token / ct0 の2つのCookieが含まれていればよい）
#   3. ログイン状態のままdevtoolsのNetworkタブを開き、いずれかのプロフィールページを
#      表示して "UserByScreenName" という名前のGraphQLリクエストを探す
#      - リクエストヘッダの `authorization: Bearer ...` の値 → X_WEB_BEARER
#      - リクエストURL `/graphql/{この部分}/UserByScreenName` → X_GRAPHQL_USERBYSCREENNAME_ID
#   4. 同様に、プロフィールページでツイート一覧をスクロールし "UserTweets" という
#      名前のGraphQLリクエストを探す
#      - リクエストURL `/graphql/{この部分}/UserTweets` → X_GRAPHQL_USERTWEETS_ID
#   5. Xの仕様変更でGraphQL経由の取得が急に失敗するようになった場合は、上記の値を
#      再度devtoolsで確認して更新すること
X_COOKIES_PATH=
X_WEB_BEARER=
X_GRAPHQL_USERBYSCREENNAME_ID=
X_GRAPHQL_USERTWEETS_ID=

# エンゲージメント率(いいね+RT+リプライ(+引用)÷フォロワー数)の算出対象とする
# 直近投稿数。X_GRAPHQL_USERTWEETS_IDが未設定の場合はengagement_rateは0.0のまま。
X_ENGAGEMENT_RECENT_POSTS=5
# 引用ツイート(quote_count)をエンゲージメント数に含めるか
X_ENGAGEMENT_INCLUDE_QUOTES=true

# --- TikTok スクレイピング設定 ---
# 【重要な制約】TikTokのプロフィールページはWAF(ボット対策)で保護されており、
# 非ログインでは統計情報を含むページ本体を取得できないことを実サイトで確認済み。
# 代わりに公式oEmbedエンドポイント（非WAF・非ログインで動作）経由でアカウントの
# 存在確認・表示名のみを取得する限定実装になっている。followers/following/
# postsCount/engagementRateは常に0固定（README「TikTokの制約」参照）。
# Cookie認証によるWAF回避・エンゲージメント算出は今後の拡張（未実装）。
TIKTOK_SEARCH_TARGET_COUNT=20
TIKTOK_DISCOVERY_MAX_CANDIDATES=30
TIKTOK_DDG_MAX_PAGES=3
TIKTOK_HYDRATE_CONCURRENCY=3
TIKTOK_JITTER_MIN=1
TIKTOK_JITTER_MAX=3
TIKTOK_PROFILE_CACHE_TTL=3600

# --- Instagram スクレイピング設定 ---
# 実サイト確認済み(2026-07-02時点): 非ログインの内部API`web_profile_info`
# （x-ig-app-id ヘッダ必須・秘匿情報ではない既知の固定値）がフォロワー数・
# フォロー数・投稿数・bio・認証バッジ・engagement_rateまでログイン壁無しで
# 返すことを確認済み。X/TikTokと異なり非認証のみでフル実装（README参照）。
INSTAGRAM_SEARCH_TARGET_COUNT=20
INSTAGRAM_DISCOVERY_MAX_CANDIDATES=30
INSTAGRAM_DDG_MAX_PAGES=3
INSTAGRAM_HYDRATE_CONCURRENCY=3
INSTAGRAM_JITTER_MIN=2
INSTAGRAM_JITTER_MAX=5
INSTAGRAM_PROFILE_CACHE_TTL=3600
INSTAGRAM_ENGAGEMENT_RECENT_POSTS=5
# IG公式Webクライアントが使う既知の固定ID。秘匿情報ではないためデフォルト値のままで良い
INSTAGRAM_IG_APP_ID=936619743392459

# --- Instagram 認証Cookie設定（任意・未設定なら非認証モードで動作、それでも実データは取得できる） ---
# 【重要】以下はMetaアカウントの認証情報そのものです。絶対にリポジトリにコミットしない
# でください。認証済みセッションを自動化してInstagramの内部APIを呼ぶ行為は利用規約に
# 抵触し得ます。Metaは（Xよりも）スクレイピング行為に積極的にアカウント凍結・法的措置
# （Bright Data/hiQ訴訟等）を取ってきた実績があるため、Xの認証Cookie運用よりも一層
# 慎重な自己責任判断・控えめな同時実行数/間隔設定を推奨します。
# このtierは必須機能ではなく、(1)ブロック・レート制限のされにくさ向上、
# (2)フォロー中の非公開アカウントの閲覧、を目的とした任意のアップグレードです。
#
# 取得手順:
#   1. ご自身のInstagram(Meta)アカウントでブラウザにログインする
#   2. Cookie-Editor等の拡張機能で instagram.com のCookieをJSON配列としてエクスポートし、
#      リポジトリ外の場所（例: ~/.secrets/meta_cookies.json）に保存する
#      （sessionidが含まれていればよい）
#   3. Instagram/Threadsは同一のMetaログイン基盤を共有するため、
#      THREADS_COOKIES_PATHを設定する場合は同じファイルを指してよい（2回エクスポート不要）
INSTAGRAM_COOKIES_PATH=

# --- Threads スクレイピング設定 ---
# 【重要な制約】実サイト確認済み(2026-07-02時点): 非ログインではプロフィールページが
# 実在/非実在を判別できるシグナルを一切返さない完全なログイン壁（TikTokのWAFより強く、
# TikTokのoEmbedのような200/400の存在確認手段すら無い）。「構文が妥当なusernameは
# 疑わしきは実在として扱う」保証フロア層のみの実装で、followers等の統計は常に0/空、
# 存在しないusernameでもスタブAccountが返ってしまう点が既知の制約（README参照）。
# Cookie認証は未実装（今後の拡張。実装する場合はINSTAGRAM_COOKIES_PATHと同じファイルを
# 指せる設計を想定）。
THREADS_SEARCH_TARGET_COUNT=20
THREADS_DISCOVERY_MAX_CANDIDATES=30
THREADS_DDG_MAX_PAGES=3
THREADS_HYDRATE_CONCURRENCY=3
THREADS_JITTER_MIN=1
THREADS_JITTER_MAX=3
THREADS_PROFILE_CACHE_TTL=3600

# --- Discovery（instagram/threads/tiktok共通）: DuckDuckGo遮断への対応（任意・両方既定無効） ---
# 実機確認済み(2026-07-02時点): このバックエンドが動くネットワーク環境でduckduckgo.com
# がISPレベルで遮断されていることが判明した（`openssl s_client`で確認した証明書が
# DuckDuckGo自身のものではなく、検閲/フィルタリングシステムのブロックページ証明書
# だった）。以下いずれかを設定することで、instagram/threads/tiktokのkeyword/hashtag/
# category検索（`queryType=username`は元々Discoveryを経由しないため無関係）がDDG遮断の
# 影響を受けずに動くようになる。詳細はREADME「トラブルシューティング」参照。

# 【推奨・主軸】Google Custom Search JSON APIをDDGの第二の発見(discovery)ソースとして使う。
# googleapis.comは同環境からブロックされていないことを確認済み（DDGのようなISPレベルの
# 遮断を構造的に回避できる。プロキシ経由でDDGに繋ぐより堅牢）。
# 取得手順:
#   1. Google Cloud Consoleで新規/既存プロジェクトの「Custom Search API」を有効化し、
#      APIキーを発行する → GOOGLE_CSE_API_KEY
#   2. https://programmablesearchengine.google.com/ で検索エンジンを新規作成し、
#      「ウェブ全体を検索」を有効にする → 検索エンジンID(cx) → GOOGLE_CSE_CX
# 【重要】無料枠は1日100クエリだが、1回の検索が*_DDG_MAX_PAGES（既定3）回分のクエリを
# 消費しうるため、実運用では数回の検索で枯渇しうる。有料枠（1000クエリ$5）を前提とする
# こと。1日10,000クエリの上限は有料でも変わらない。
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# 【補助・緊急退避用】DDGへの接続専用のオプトインHTTPプロキシ。他プラットフォーム
# （instagram.com/x.com/tiktok.comのoEmbed等）の通信には一切使わない設計（Cookie付き
# 認証リクエストが意図せずプロキシを経由する事故を防ぐため）。共有・データセンター系
# プロキシの出口IPは他テナントのトラフィックと共有され、DDG側から見て既にレート制限/
# ブロック対象になっている可能性がある点に注意（net.pyの礼儀正しさの前提が崩れうる。
# 上記のGoogle CSEの方が構造的に堅牢なため基本はそちらを推奨）。
# 例: http://user:pass@host:port
DISCOVERY_PROXY_URL=

# フロントエンド(Vite dev server)のオリジン — CORS許可用（複数はカンマ区切り）
CORS_ALLOW_ORIGINS=http://localhost:5173

APP_VERSION=0.1.0
